generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id                String   @id @default(uuid()) @db.Uuid
  title             String   @db.Text
  slug              String?  @db.VarChar(255)
  summary           String?  @db.Text
  content           String?  @db.Text
  image_url         String?  @db.Text
  category          String   @db.VarChar(64)
  source            String   @db.VarChar(128)
  source_url        String   @unique @db.Text
  published_at      DateTime @db.Timestamptz(6)
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  views             Int      @default(0)
  shares            Int      @default(0)
  word_count        Int?
  trending_score    Float    @default(0)
  ai_summary        String?  @db.Text
  ai_rewritten      Boolean  @default(false)
  raw_content       String?  @db.Text
  image_storage_url String?  @db.Text
  is_featured       Boolean  @default(false)
  featured_until    DateTime? @db.Timestamptz(6)
  manual_upload     Boolean  @default(false)
  updated_at        DateTime @updatedAt @db.Timestamptz(6)

  @@index([category, created_at])
  @@index([is_featured, featured_until, created_at])
  @@index([published_at])
  @@index([trending_score])
  @@map("articles")
}
